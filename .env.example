# Optional overrides for docker compose / local run

# JWT
APP_JWT_SECRET=CHANGE_ME_IN_PROD_CHANGE_ME_IN_PROD_CHANGE_ME_IN_PROD_123456
APP_JWT_EXPIRATIONMINUTES=120

# Bootstrap admin
APP_BOOTSTRAP_ADMIN_EMAIL=admin@local
